<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="64dp" android:layout_height="64dp"
    android:background="@drawable/floating_ball_bg">

    <View android:id="@+id/ball_pulse"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="@drawable/floating_ball_pulse"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical" android:gravity="center">
        <ImageView android:id="@+id/ball_icon"
            android:layout_width="24dp" android:layout_height="24dp"
            android:src="@drawable/ic_launcher_foreground" />
        <TextView android:id="@+id/ball_value"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="0" android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View android:id="@+id/ball_status"
        android:layout_width="10dp" android:layout_height="10dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="3dp" android:layout_marginEnd="3dp"
        android:background="@drawable/floating_ball_status" />
</FrameLayout>